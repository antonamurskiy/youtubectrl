{
  "appId": "com.antonamurskiy.ytctl1289",
  "appName": "Vids",
  "webDir": "www",
  "server": {
    "url": "http://yuzu.local:3000",
    "cleartext": true,
    "allowNavigation": [
      "yuzu.local",
      "*.googlevideo.com",
      "*.youtube.com",
      "i.ytimg.com"
    ]
  },
  "ios": {
    "contentInset": "never",
    "limitsNavigationsToAppBoundDomains": false,
    "webContentsDebuggingEnabled": true,
    "allowsLinkPreview": false,
    "scrollEnabled": true,
    "backgroundColor": "#212121ff"
  },
  "plugins": {
    "SplashScreen": {
      "launchAutoHide": false,
      "backgroundColor": "#212121",
      "showSpinner": false
    },
    "StatusBar": {
      "style": "DARK",
      "backgroundColor": "#212121",
      "overlaysWebView": false
    }
  }
}
